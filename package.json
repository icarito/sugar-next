{
  "name": "sugarlabs-workspace",
  "version": "0.121.0",
  "private": true,
  "type": "module",
  "description": "Sugar Labs GTK4 modernization monorepo workspace root",
  "repository": {
    "type": "git",
    "url": "https://github.com/sugarlabs/sugar.git"
  },
  "scripts": {
    "run": "make run",
    "debug": "make debug",
    "setup": "make setup",
    "test": "make test",
    "lint": "make lint",
    "format": "make format",
    "clean": "make clean",
    "build:casilda": "cd repos/casilda && meson setup _build && ninja -C _build",
    "build:toolkit-gtk4": "cd repos/sugar-toolkit-gtk4 && pip install -e .",
    "build:sugar": "cd repos/sugar && autoreconf -fi && ./configure --prefix=/usr && make"
  },
  "workspaces": [
    "repos/sugar-toolkit-gtk4"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "sugar",
    "sugarlabs",
    "gtk4",
    "education",
    "desktop-environment"
  ],
  "license": "GPL-3.0-or-later"
}
